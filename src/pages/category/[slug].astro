---
import { getCollection } from 'astro:content';
import Nav from '../../components/Nav.astro';
import { slugify, getOptimizedImageUrl, getResponsiveSrcSet } from '../../lib/utils';

export async function getStaticPaths() {
  const categories = await getCollection('categories');

  return categories.map((category) => ({
    params: { slug: slugify(category.data.name) },
    props: { category },
  }));
}

const { category } = Astro.props;
const images = category.data.images ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{category.data.name}</title>
  </head>
  <body>
    <header>
      <Nav />
    </header>

    <main>
      <h1>{category.data.name}</h1>
      <section>
        {images.map((img) => (
          <figure>
            <img
              src={getOptimizedImageUrl(img.photo.url, { size: 'large' })}
              srcset={getResponsiveSrcSet(img.photo.url)}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 1200px"
              width={img.photo.width}
              height={img.photo.height}
              alt=""
              loading="lazy"
              decoding="async"
            />
          </figure>
        ))}
      </section>
    </main>
  </body>
</html>
